# Copy this file to .env and fill in your credentials
# DO NOT commit .env to version control

IBM_QUANTUM_TOKEN=your_ibm_quantum_token_here
# Available backends: ibm_kingston, ibm_fez, ibm_marrakesh, ibm_torino
IBM_QUANTUM_BACKEND=ibm_fez
IBM_QUANTUM_INSTANCE=ibm-q/open/main
SUPERSTAQ_API_TOKEN=your_superstaq_token_here
